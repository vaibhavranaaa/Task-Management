{
  "info": {
    "name": "Task Management API v2",
    "description": "Complete collection for Task Management API v2 — includes Auth, Tasks (with categories & tags), Categories, and demonstration of reminders + webhooks.\n\nSetup:\n1. Set `baseUrl` variable to `http://localhost:3000`\n2. Run Register or Login — token is saved automatically\n3. All protected requests use {{token}} automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token",   "value": "" },
    { "key": "taskId",  "value": "" },
    { "key": "categoryId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": ["const j = pm.response.json(); if(j.token) pm.collectionVariables.set('token', j.token);"] } }],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Vaibhav Rana\",\n  \"email\": \"vaibhav@example.com\",\n  \"password\": \"Secret123\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["const j = pm.response.json(); if(j.token) pm.collectionVariables.set('token', j.token);"] } }],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"vaibhav@example.com\",\n  \"password\": \"Secret123\"\n}" }
          }
        },
        {
          "name": "Get My Profile",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/auth/me", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category - Work",
          "event": [{ "listen": "test", "script": { "exec": ["const j = pm.response.json(); if(j.data && j.data.category) pm.collectionVariables.set('categoryId', j.data.category._id);"] } }],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/v1/categories",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Work\",\n  \"color\": \"#6366f1\",\n  \"description\": \"Work related tasks\"\n}" }
          }
        },
        {
          "name": "Create Category - Personal",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/v1/categories",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Personal\",\n  \"color\": \"#10b981\",\n  \"description\": \"Personal tasks\"\n}" }
          }
        },
        {
          "name": "Create Category - Urgent",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/v1/categories",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Urgent\",\n  \"color\": \"#ef4444\",\n  \"description\": \"High priority urgent tasks\"\n}" }
          }
        },
        {
          "name": "Get All Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/categories", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Get Category by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/categories/{{categoryId}}", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/v1/categories/{{categoryId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated work category description\"\n}" }
          }
        },
        {
          "name": "Delete Category",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v1/categories/{{categoryId}}", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task (with category + tags)",
          "event": [{ "listen": "test", "script": { "exec": ["const j = pm.response.json(); if(j.data && j.data.task) pm.collectionVariables.set('taskId', j.data.task._id);"] } }],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/v1/tasks",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Complete API assignment\",\n  \"description\": \"Finish building the task management API\",\n  \"dueDate\": \"2027-01-15T10:00:00.000Z\",\n  \"status\": \"pending\",\n  \"category\": \"{{categoryId}}\",\n  \"tags\": [\"high-priority\", \"backend\", \"assignment\"]\n}" }
          }
        },
        {
          "name": "Create Task (reminder demo - 2 min from now)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/v1/tasks",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"REMINDER DEMO TASK\",\n  \"description\": \"Set REMINDER_LEAD_TIME_OVERRIDE_MS=60000 and dueDate 2 mins from now to see reminder fire\",\n  \"dueDate\": \"2027-12-31T23:59:00.000Z\",\n  \"tags\": [\"demo\", \"reminder\"]\n}" }
          }
        },
        {
          "name": "Get All Tasks",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tasks", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Filter by Status",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/tasks?status=pending", "host": ["{{baseUrl}}"], "path": ["api","v1","tasks"], "query": [{ "key": "status", "value": "pending" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Filter by Category",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/tasks?category={{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","tasks"], "query": [{ "key": "category", "value": "{{categoryId}}" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Filter by Tags",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/tasks?tags=high-priority,backend", "host": ["{{baseUrl}}"], "path": ["api","v1","tasks"], "query": [{ "key": "tags", "value": "high-priority,backend" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Filter by Category + Tags + Sort",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/tasks?category={{categoryId}}&tags=backend&sortBy=dueDate&order=asc", "host": ["{{baseUrl}}"], "path": ["api","v1","tasks"], "query": [{ "key": "category", "value": "{{categoryId}}" }, { "key": "tags", "value": "backend" }, { "key": "sortBy", "value": "dueDate" }, { "key": "order", "value": "asc" }] },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Task by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Update Task Tags",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"tags\": [\"high-priority\", \"backend\", \"completed-phase-1\"]\n}" }
          }
        },
        {
          "name": "Mark Task Completed (fires webhook!)",
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"completed\"\n}" }
          }
        },
        {
          "name": "Delete Task",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        },
        {
          "name": "Access Another User's Task (should 403)",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tasks/000000000000000000000001", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }] }
        }
      ]
    },
    {
      "name": "Error / Validation Demos",
      "item": [
        {
          "name": "Missing title (400)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/v1/tasks",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"dueDate\": \"2027-01-01T00:00:00.000Z\"\n}" }
          }
        },
        {
          "name": "Past due date (400)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/v1/tasks",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Past task\",\n  \"dueDate\": \"2020-01-01T00:00:00.000Z\"\n}" }
          }
        },
        {
          "name": "No auth token (401)",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tasks" }
        },
        {
          "name": "Invalid category hex color (400)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/v1/categories",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Bad Color\",\n  \"color\": \"red\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" }
        }
      ]
    }
  ]
}