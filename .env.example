# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# ─── PostgreSQL (User Data) ────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=taskmanager_users
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# ─── MongoDB (Task Data) ───────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/taskmanager_tasks

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Webhooks ──────────────────────────────────────────────────────────────────
# Analytics webhook: fires when a task is marked completed (with retry logic)
# Get a free test URL from https://webhook.site
ANALYTICS_WEBHOOK_URL=https://webhook.site/your-unique-id

# Notification webhook: fires when a reminder triggers (optional)
NOTIFICATION_WEBHOOK_URL=https://webhook.site/your-unique-id

# ─── Reminder Scheduling ───────────────────────────────────────────────────────
# Default: fire reminder 1 hour (3600000ms) before due date.
# For testing, override to a small value e.g. 60000 = 1 minute before due date.
REMINDER_LEAD_TIME_OVERRIDE_MS=